# ========================================================
# Production Environment Variables Template
# Global Star Track Export Website
# ========================================================

# --- Core Site Configuration ---
# The canonical domain address of your deployed production website (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://globalstartrack.com

# --- Admin Authentication ---
# Credentials for accessing the administrator dashboard panel (/admin-panel).
ADMIN_USERNAME=admin
# Use a strong, random password for production.
ADMIN_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
# Secret key used to encrypt/verify administrator JWT session tokens (recommend 64-char hex string).
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY

# --- Supabase Integration (Required in Production) ---
# Project API endpoint URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Client connection anonymous key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anonymous-key-here
# High-privilege service-role key (used for server-side database writes and storage upload operations).
# KEEP THIS SECRET! Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- B2B Contact Fallback Settings ---
# FALLBACK: Support email address displayed in layout links if none exists in db.
NEXT_PUBLIC_SUPPORT_EMAIL=Info@globalstartrack.com
# FALLBACK: Mobile telephone number for WhatsApp redirection widgets (with country code, no + or spaces).
NEXT_PUBLIC_WHATSAPP_NUMBER=918799644050

# --- Analytics & Search Console (Optional) ---
# Google Analytics GA4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Search Console HTML Verification code
NEXT_PUBLIC_GSC_VERIFICATION=

# --- Sentry Error Monitoring (Optional) ---
# Public DSN for tracking frontend errors
NEXT_PUBLIC_SENTRY_DSN=
# Private DSN for tracking backend exceptions
SENTRY_DSN=

# --- Contact Form Email Notifications (Optional - Configure ONE) ---
# Option A: SendGrid Integration
SENDGRID_API_KEY=
SENDGRID_MAIL_FROM=noreply@globalstartrack.com
SENDGRID_MAIL_TO=Info@globalstartrack.com
# Fallback email recipient used if SENDGRID_MAIL_TO is omitted
CONTACT_NOTIFY_EMAIL=

# Option B: Direct SMTP Configurations (fallback if SendGrid is unconfigured)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Contact Form WhatsApp Alerts (Optional) ---
# Twilio REST Client parameters to dispatch SMS/WhatsApp notifications on new inquiries.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+918799644050
# Fallback WhatsApp click redirect message address
WHATSAPP_TO_FALLBACK=918799644050

# --- Rate Limiting (Optional) ---
# Controls inquiry rate limiting limits (default is 10 requests per 10min window)
CONTACT_RATE_LIMIT_MAX=10
CONTACT_RATE_LIMIT_WINDOW_MS=600000
